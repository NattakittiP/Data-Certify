# ===================================================================
# DATA-CERTIFY — .gitignore
# ===================================================================

# ----- Python build / packaging artifacts -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
wheels/
*.egg
MANIFEST

# ----- Testing / linting / type-checking caches -----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# ----- Virtual environments -----
.venv/
venv/
env/
ENV/
.python-version

# ----- Jupyter -----
.ipynb_checkpoints/

# ----- OS junk -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Editor / IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Secrets (defensive; project does not currently require any) -----
.env
.env.*
*.pem
*.key
credentials.json

# ===================================================================
# Project-specific — only the core library + entry-point scripts are
# published. Internal docs, calibration/verification tooling, the test
# suite, and all raw data are kept local and NOT uploaded to GitHub.
# ===================================================================

# Internal theory/validation documentation.
Docs/

# Calibration, corpus-building, and verification tooling (not part of
# the shipped system — used only to derive/validate weights & thresholds).
calibration/
run_all.sh
fetch_theta_auth_references.py

# Test suite (kept local; not published).
tests/
pytest.ini
.pytest_cache/

# Raw / derived seismic-catalog data — not published, EXCEPT the two
# small real-catalog demo datasets (nz, chile) that the README Quick
# Start and examples/example_nz_chile_audit.py actually run against.
Dataset/
datasets_adversarial/
usgs_reference_fetch/
dev_diagnostics/

datasets/*
!datasets/nz/
!datasets/chile/

# Stale backup / scratch files inside the chile demo folder — keep only
# the clean, current records.csv.
datasets/chile/*.bak_*
datasets/chile/records_NUL_CORRUPTED.csv
datasets/chile/records_OLD_pre_geofilter.csv.csv
datasets/chile/audit_result.json

# Packaging metadata generated by `pip install -e .`
data_certify.egg-info/
